# Orchestrator defaults (template — copy to .env.local and fill in secrets)
CODEBOX_IMAGE=codebox-sandbox:latest
ORCHESTRATOR_PORT=8080
WORKSPACE_BASE_DIR=/workspaces
DOCKER_NETWORK=codebox-net
DATABASE_URL=sqlite+aiosqlite:////data/orchestrator.db

# Set these in .env.local
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
