# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codebox

# ── Server infrastructure ─────────────────────────────────────────
CODEBOX_IMAGE=codebox-sandbox:latest
ORCHESTRATOR_PORT=9090
WORKSPACE_BASE_DIR=/workspaces
DOCKER_NETWORK=codebox-net
ORCHESTRATOR_GRPC_ADDRESS=
GRPC_PORT=50051

# ── Container runtime ────────────────────────────────────────────
CONTAINER_RUNTIME_URL=
CONTAINER_RUNTIME_TYPE=docker
CONTAINER_TLS_VERIFY=
CONTAINER_TLS_CERT=
CONTAINER_TLS_KEY=

# ── Secrets (required) ───────────────────────────────────────────
# All three secrets below are required. Generate values with the commands shown.

# Master key for encrypting API keys and secrets in the database.
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT signing secrets.
# python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET=
CALLBACK_SECRET=

# ── Web UI ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3737
AUTH_TOKEN_EXPIRY_HOURS=24
