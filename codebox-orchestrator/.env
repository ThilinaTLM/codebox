# Orchestrator defaults (template — copy secrets to .env.local / .env.compose)
CODEBOX_IMAGE=codebox-sandbox:latest
ORCHESTRATOR_PORT=9090
WORKSPACE_BASE_DIR=/workspaces
DOCKER_NETWORK=codebox-net
ORCHESTRATOR_GRPC_ADDRESS=

# Container runtime (leave empty for local Docker socket via docker.from_env())
CONTAINER_RUNTIME_URL=
CONTAINER_RUNTIME_TYPE=docker
CONTAINER_TLS_VERIFY=
CONTAINER_TLS_CERT=
CONTAINER_TLS_KEY=

# Set these in .env.local (local dev) or .env.compose (docker compose)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
TAVILY_API_KEY=

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=codebox-dev
