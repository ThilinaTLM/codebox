# ══════════════════════════════════════════════════════════════════
# Codebox orchestrator — environment reference
# ══════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in values. `.env` is gitignored.
# Every setting the orchestrator knows about is listed below; defaults
# are shown after each key. See `src/codebox_orchestrator/config.py`
# for the full schema.
# ══════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────
# "development" | "production" | (anything else counts as non-dev)
# In non-development environments the three secrets below are required.
CODEBOX_ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────
# Standard SQLAlchemy URL with the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codebox

# ── Box (sandbox) runtime ────────────────────────────────────────
CODEBOX_BOX_IMAGE=codebox-sandbox:latest
CODEBOX_BOX_NETWORK=codebox-sandbox-net
CODEBOX_BOX_MEMORY_LIMIT=4g
CODEBOX_BOX_CPU_LIMIT=2
CODEBOX_BOX_PIDS_LIMIT=1024

# ── Orchestrator HTTP server ─────────────────────────────────────
CODEBOX_ORCHESTRATOR_HTTP_HOST=0.0.0.0
CODEBOX_ORCHESTRATOR_HTTP_PORT=9090

# ── Orchestrator gRPC server ─────────────────────────────────────
CODEBOX_ORCHESTRATOR_GRPC_PORT=50051

# ── Public URLs that Box containers use to reach the orchestrator ──
# Leave unset in local dev — defaults auto-detect host.docker.internal
# / host.containers.internal based on CODEBOX_CONTAINER_RUNTIME.
# Override in production to your public/internal orchestrator endpoints.
# CODEBOX_ORCHESTRATOR_URL=https://orchestrator.example.com
# CODEBOX_ORCHESTRATOR_GRPC_URL=grpcs://orchestrator.example.com:50051

# ── gRPC TLS (optional, for secure deployments) ──────────────────
# CODEBOX_GRPC_TLS_CERT=/etc/grpc-certs/server.crt
# CODEBOX_GRPC_TLS_KEY=/etc/grpc-certs/server.key
# CODEBOX_GRPC_TLS_CA_CERT=/etc/grpc-certs/ca.crt
# CODEBOX_GRPC_TLS_ENABLED=false

# ── Container runtime (Docker / Podman daemon) ───────────────────
CODEBOX_CONTAINER_RUNTIME=docker
# CODEBOX_CONTAINER_RUNTIME_URL=
# CODEBOX_CONTAINER_TLS_VERIFY=
# CODEBOX_CONTAINER_TLS_CERT=
# CODEBOX_CONTAINER_TLS_KEY=

# ── Required secrets (generate values for production) ────────────
# Master key for encrypting API keys and secrets in the database.
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CODEBOX_ENCRYPTION_KEY=

# JWT signing secrets.
# python -c "import secrets; print(secrets.token_urlsafe(64))"
CODEBOX_AUTH_SECRET=
CODEBOX_CALLBACK_SECRET=

# ── Auth / callback token expiry ─────────────────────────────────
CODEBOX_AUTH_TOKEN_EXPIRY_HOURS=168
CODEBOX_CALLBACK_TOKEN_EXPIRY_SECONDS=3600

# ── Web UI CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CODEBOX_CORS_ORIGINS=http://localhost:3737

# ── Initial admin bootstrap (first-time only) ────────────────────
# Only consulted when the users table is empty. If unset, a random
# password is generated and logged on first boot.
# CODEBOX_ADMIN_USERNAME=admin
# CODEBOX_ADMIN_PASSWORD=
