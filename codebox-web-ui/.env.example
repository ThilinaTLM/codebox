# Copy this file to `.env` and tweak for your machine.
# `.env` is gitignored; `.env.example` is committed.

# Backend API base URL used by server-side rendering (Nitro) to fetch
# from the orchestrator. In deployments this is usually an *internal*
# address (e.g. a Docker service name) so SSR fetches don't hairpin
# through the public load balancer.
CODEBOX_API_URL=http://localhost:9090

# Public orchestrator URL hydrated into the browser. Only needed when
# the server-side `CODEBOX_API_URL` is not reachable from a browser
# (typical in production where SSR uses an internal service name).
# Leave unset for local dev.
# CODEBOX_PUBLIC_API_URL=https://api.codebox.example.com
