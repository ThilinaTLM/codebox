# Copy this file to `.env` and tweak for your machine.
# `.env` is gitignored; `.env.example` is committed.

# Backend API base URL. Used by the Nitro SSR server (process.env) and
# injected into the browser as window.__ENV__.CODEBOX_API_URL for SPA
# requests + SSE streams.
CODEBOX_API_URL=http://localhost:9090
